---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DetailHeader from '../../components/DetailHeader.astro';
import JsonLd from '../../components/JsonLd.astro';
import { SITE_TITLE } from '../../consts';
import { breadcrumbJsonLd, articleJsonLd } from '../../lib/seo';
import '../../styles/global.css';

export async function getStaticPaths() {
	const stories = await getCollection('stories');
	return stories.map((story) => ({
		params: { id: story.id },
		props: { story },
	}));
}

const { story } = Astro.props;
const { Content } = await render(story);
const title = `${story.data.title} - ${SITE_TITLE}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const d = story.data;

const breadcrumbItems = [
	{ label: '首页', href: '/' },
	{ label: '剧情', href: '/stories' },
	{ label: d.title },
];

const badges = [
	{ label: d.type },
	d.chapter && { label: d.chapter },
	d.section && { label: d.section },
].filter(Boolean) as { label: string }[];

const meta = [
	d.characters && d.characters.length > 0 && { label: '出场角色', value: d.characters.join('、') },
].filter(Boolean) as { label: string; value: string }[];
---

<BaseLayout title={title} description={d.description}>
	<main>
		<Breadcrumbs items={breadcrumbItems} />

		<DetailHeader
			title={d.title}
			description={d.description}
			badges={badges}
			meta={meta}
		/>

		{
			d.source && (
				<p class="data-source">
					来源：
					<a href={d.source} target="_blank" rel="noopener noreferrer">
						无期迷途 BWiki
					</a>
				</p>
			)
		}

		<section class="story-content card">
			<Content />
		</section>
	</main>

	<JsonLd data={breadcrumbJsonLd(breadcrumbItems, Astro.site)} />
	<JsonLd data={articleJsonLd({ title, description: d.description, url: canonicalUrl, site: Astro.site })} />
</BaseLayout>

<style>
	.data-source {
		font-size: 0.9em;
		color: rgb(var(--gray));
		margin: -0.5em 0 1em;
	}
	.story-content {
		padding: 1.5em;
	}
	.story-content :global(p) {
		margin-bottom: 1em;
	}
</style>
