---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE_TITLE } from '../../consts';
import '../../styles/global.css';

const updates = (await getCollection('updates')).sort((a, b) =>
	b.data.date.localeCompare(a.data.date)
);

const types = ['全部', '版本更新', '活动', '维护公告', '站点公告', '其他'];
const todayStr = new Date().toISOString().slice(0, 10);

function getStatus(update: (typeof updates)[number]) {
	const { date, endDate } = update.data;
	if (endDate && todayStr >= date && todayStr <= endDate) {
		return { label: '进行中', cls: 'status-ongoing' };
	}
	if (todayStr < date) {
		return { label: '即将开始', cls: 'status-upcoming' };
	}
	return { label: '已结束', cls: 'status-past' };
}

const grouped = new Map<string, typeof updates>();
updates.forEach((u) => {
	const month = u.data.date.slice(0, 7);
	if (!grouped.has(month)) grouped.set(month, []);
	grouped.get(month)!.push(u);
});

const breadcrumbItems = [
	{ label: '首页', href: '/' },
	{ label: '活动日历' },
];
---

<BaseLayout
	title={`版本活动日历 - ${SITE_TITLE}`}
	description="无期迷途版本更新、限时活动与维护公告日历。"
>
	<main>
		<Breadcrumbs items={breadcrumbItems} />
		<h1 class="page-title">版本活动日历</h1>
		<p class="page-desc">按时间线查看版本更新、活动与维护公告</p>

		<div class="filters">
			{
				types.map((type, idx) => (
					<button class={`tab${idx === 0 ? ' active' : ''}`} data-type={type === '全部' ? '' : type}>
						{type}
					</button>
				))
			}
			<span id="count">共 {updates.length} 条</span>
		</div>

		<div class="timeline" id="timeline">
			{
				[...grouped.entries()].map(([month, list]) => (
					<div class="month-group" data-month={month}>
						<h2 class="month-title">{month}</h2>
						<div class="month-list">
							{list.map((u) => {
								const status = getStatus(u);
								return (
									<a
										href={`/updates/${u.id}/`}
										class="timeline-item"
										data-type={u.data.type}
									>
										<div class="timeline-date">
											<span>{u.data.date}</span>
											{u.data.endDate && <span> 至 {u.data.endDate}</span>}
										</div>
										<div class="timeline-content">
											<div class="item-header">
												<span class="badge type-badge">{u.data.type}</span>
												<span class={`badge ${status.cls}`}>{status.label}</span>
											</div>
											<h3>{u.data.title}</h3>
											<p>{u.data.description}</p>
										</div>
									</a>
									);
								})}
							</div>
						</div>
					))
				}
			</div>
			<p class="empty-tip" id="empty-tip" style="display: none;">
				该分类下暂无记录。
			</p>
	</main>
</BaseLayout>

<script is:inline>
	(function () {
		const tabs = document.querySelectorAll('.filters .tab');
		const items = document.querySelectorAll('#timeline .timeline-item');
		const groups = document.querySelectorAll('#timeline .month-group');
		const countEl = document.getElementById('count');
		const emptyTip = document.getElementById('empty-tip');

		function isHidden(el) {
			return el.style.display === 'none';
		}

		function filter() {
			const active = document.querySelector('.filters .tab.active');
			const type = active ? active.dataset.type || '' : '';
			let visible = 0;

			items.forEach((item) => {
				const show = !type || item.dataset.type === type;
				item.style.display = show ? '' : 'none';
				if (show) visible++;
			});

			groups.forEach((group) => {
				const hasVisible = Array.from(group.querySelectorAll('.timeline-item')).some(
					(item) => !isHidden(item)
				);
				group.style.display = hasVisible ? '' : 'none';
			});

			countEl.textContent = `共 ${visible} 条`;
			emptyTip.style.display = visible === 0 ? '' : 'none';
		}

		tabs.forEach((tab) => {
			tab.addEventListener('click', () => {
				tabs.forEach((t) => t.classList.remove('active'));
				tab.classList.add('active');
				filter();
			});
		});
	})();
</script>

<style>
	.filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6em;
		align-items: center;
		margin-bottom: 1.5em;
	}
	.tab {
		padding: 0.4em 0.9em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
		background: #fff;
		cursor: pointer;
		font-size: 0.9em;
		color: rgb(var(--gray-dark));
	}
	.tab.active {
		background: var(--accent);
		color: #fff;
		border-color: var(--accent);
	}
	#count {
		margin-left: auto;
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
	.month-group {
		margin-bottom: 2em;
	}
	.month-title {
		font-size: 1.3em;
		margin-bottom: 0.6em;
		color: var(--accent-dark);
	}
	.month-list {
		display: grid;
		gap: 0.8em;
	}
	.timeline-item {
		display: grid;
		grid-template-columns: 140px 1fr;
		gap: 1em;
		padding: 1em 1.2em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		background: #fff;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s, box-shadow 0.2s;
	}
	.timeline-item:hover {
		border-color: var(--accent);
		box-shadow: 0 4px 12px rgba(var(--gray), 10%);
	}
	.timeline-date {
		font-size: 0.85em;
		color: rgb(var(--gray));
		font-weight: 500;
	}
	.item-header {
		display: flex;
		gap: 0.5em;
		flex-wrap: wrap;
		margin-bottom: 0.4em;
	}
	.type-badge {
		background: #eef2ff;
		color: var(--accent-dark);
	}
	.status-ongoing {
		background: #dcfce7;
		color: #166534;
	}
	.status-upcoming {
		background: #fef3c7;
		color: #92400e;
	}
	.status-past {
		background: rgb(var(--gray-light));
		color: rgb(var(--gray));
	}
	.timeline-content h3 {
		margin: 0.2em 0;
		font-size: 1.1em;
	}
	.timeline-content p {
		margin: 0;
		font-size: 0.9em;
		color: rgb(var(--gray));
	}
	.empty-tip {
		text-align: center;
		color: rgb(var(--gray));
		margin-top: 2em;
	}
	@media (max-width: 720px) {
		.timeline-item {
			grid-template-columns: 1fr;
			gap: 0.4em;
		}
	}
</style>
