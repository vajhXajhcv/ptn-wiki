---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE_TITLE } from '../../consts';
import '../../styles/global.css';

export async function getStaticPaths() {
	const characters = await getCollection('characters');
	return characters.map((character) => ({
		params: { id: character.id },
		props: { character },
	}));
}

const { character } = Astro.props;
const { Content } = await render(character);
const title = `${character.data.name} - ${SITE_TITLE}`;
const ogImage = character.data.image || undefined;

const breadcrumbItems = [
	{ label: '首页', href: '/' },
	{ label: '角色图鉴', href: '/characters' },
	{ label: character.data.name },
];

const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: breadcrumbItems.map((item, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: item.label,
		item: item.href ? new URL(item.href, Astro.site).toString() : undefined,
	})),
};
---

<BaseLayout title={title} description={character.data.description} image={ogImage}>
	<main>
		<Breadcrumbs items={breadcrumbItems} />

		<article class="character-header">
			{character.data.image && (
				<img
					src={character.data.image}
					alt={character.data.name}
					class="character-image"
					loading="eager"
					decoding="async"
				/>
			)}
			<div class="character-info">
				<h1 class="page-title">{character.data.name}</h1>
				{character.data.title && <p class="page-desc character-subtitle">{character.data.title}</p>}

				<div class="info-badges">
					{character.data.rarity && (
						<span class:list={['badge', `rarity-${character.data.rarity.toLowerCase()}`]}>
							{character.data.rarity}级
						</span>
					)}
					{character.data.danger && <span class="badge">{character.data.danger}</span>}
					{character.data.role && <span class="badge">{character.data.role}</span>}
					{character.data.faction && <span class="badge">{character.data.faction}</span>}
				</div>

				{character.data.tags && character.data.tags.length > 0 && (
					<div class="tag-list">
						{character.data.tags.map((tag) => (
							<span class="badge badge-tag">{tag}</span>
						))}
					</div>
				)}

				{character.data.description && (
					<p class="character-description">{character.data.description}</p>
				)}
			</div>
		</article>

		<div class="prose character-body">
			<Content />
		</div>

		<p class="data-source">
			角色图片素材来自《无期迷途》官方网站；技能名称、效果等客观数据参考无期迷途 BWiki 整理。
		</p>
	</main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

<style>
	.character-header {
		display: grid;
		grid-template-columns: 260px 1fr;
		gap: 2em;
		align-items: start;
		margin-bottom: 2em;
		padding: 1.5em;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 16px;
		box-shadow: 0 4px 12px rgba(var(--gray), 12%);
	}
	.character-image {
		width: 100%;
		max-width: 260px;
		border-radius: 12px;
		object-fit: cover;
		margin: 0;
	}
	.character-info {
		min-width: 0;
	}
	.character-subtitle {
		margin-top: -0.3em;
		font-size: 1.05em;
	}
	.character-description {
		margin-top: 1em;
		color: rgb(var(--gray-dark));
		font-size: 0.95em;
		line-height: 1.7;
	}
	.info-badges {
		margin: 0.8em 0 0.5em;
	}
	.tag-list {
		margin: 0.5em 0;
	}
	.badge-tag {
		font-size: 0.75em;
		background: #eef2ff;
		color: var(--accent-dark);
	}
	.character-body {
		margin-top: 1.5em;
	}
	.character-body h2 {
		margin-top: 1.5em;
		padding-bottom: 0.3em;
		border-bottom: 2px solid rgb(var(--gray-light));
	}
	.character-body h3 {
		margin-top: 1.2em;
		font-size: 1.2em;
		color: var(--accent-dark);
	}
	.character-body ul {
		padding-left: 1.5em;
	}
	.character-body li {
		margin-bottom: 0.5em;
	}
	.data-source {
		margin-top: 3em;
		padding-top: 1.5em;
		border-top: 1px solid rgb(var(--gray-light));
		color: rgb(var(--gray));
		font-size: 0.8em;
		text-align: center;
	}
	@media (max-width: 720px) {
		.character-header {
			grid-template-columns: 1fr;
			justify-items: center;
			text-align: center;
		}
		.character-image {
			max-width: 220px;
		}
		.character-info {
			width: 100%;
		}
	}
</style>
