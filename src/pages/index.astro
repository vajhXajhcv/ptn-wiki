---
import fs from 'node:fs';
import path from 'node:path';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import '../styles/global.css';

const characters = await getCollection('characters');
const stages = await getCollection('stages');
const gameModes = await getCollection('gameModes');
const updates = await getCollection('updates');
const stories = await getCollection('stories');

// 按文件修改时间排序，取最近更新的 6 名角色
const charactersWithMtime = characters.map((character) => {
	const filePath = path.join(process.cwd(), 'src', 'content', 'characters', `${character.id}.md`);
	const { mtimeMs } = fs.statSync(filePath);
	return { ...character, mtimeMs };
});
const recentCharacters = [...charactersWithMtime]
	.sort((a, b) => b.mtimeMs - a.mtimeMs)
	.slice(0, 6);

// 随机推荐 6 名 S 级角色
const recommendedCharacters = characters
	.filter((c) => c.data.rarity === 'S')
	.sort(() => 0.5 - Math.random())
	.slice(0, 6);

const quickLinks = [
	{
		label: '角色图鉴',
		href: '/characters',
		desc: `查看全部 ${characters.length} 名角色`,
	},
	{
		label: '关卡攻略',
		href: '/stages',
		desc: `查看全部 ${stages.length} 个关卡`,
	},
	{
		label: '玩法攻略',
		href: '/game-modes',
		desc: `暗域、公会战、数据间隙等玩法`,
	},
	{
		label: '剧情文本',
		href: '/stories',
		desc: `查看全部 ${stories.length} 段剧情`,
	},
	{
		label: '社区工具',
		href: '/community',
		desc: '开源项目、Wiki 与实用工具整理',
	},
	{
		label: '参与贡献',
		href: 'https://github.com/vajhXajhcv/ptn-wiki',
		desc: '提交 PR、反馈问题或加入讨论',
	},
];

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	url: Astro.site?.toString(),
	description: SITE_DESCRIPTION,
	potentialAction: {
		'@type': 'SearchAction',
		target: new URL('/search?q={search_term_string}', Astro.site).toString(),
		'query-input': 'required name=search_term_string',
	},
};
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main>
		<section class="hero">
			<h1 class="hero-title">{SITE_TITLE}</h1>
			<p class="hero-desc">{SITE_DESCRIPTION}</p>
			<p class="hero-sub">
				非官方、非营利、玩家共建的《无期迷途》中文资料站
			</p>
			<div class="hero-links">
				<a href="/characters" class="hero-btn">浏览角色</a>
				<a href="/stages" class="hero-btn hero-btn-secondary">查看关卡</a>
			</div>
		</section>

		<section class="section">
			<h2 class="section-title">快速入口</h2>
			<div class="card-grid quick-links">
				{quickLinks.map((link) => (
					<a href={link.href} class="card quick-link-card">
						<h3>{link.label}</h3>
						<p>{link.desc}</p>
					</a>
				))}
			</div>
		</section>

		{updates.length > 0 && (
			<section class="section">
				<div class="section-header">
					<h2 class="section-title">最新动态</h2>
					<a href="/updates" class="section-more">查看全部 →</a>
				</div>
				<div class="update-list">
					{updates
						.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
						.slice(0, 3)
						.map((u) => (
							<a href={`/updates/${u.id}/`} class="update-card">
								<span class="update-date">{u.data.date}</span>
								<span class="update-type">{u.data.type}</span>
								<strong>{u.data.title}</strong>
							</a>
						))}
				</div>
			</section>
		)}

		<section class="section">
			<div class="section-header">
				<h2 class="section-title">最近更新</h2>
				<a href="/characters" class="section-more">查看全部 →</a>
			</div>
			<div class="card-grid">
				{recentCharacters.map((c) => (
					<a href={`/characters/${c.id}/`} class="card char-card">
						{c.data.image && (
							<img
								src={c.data.image}
								alt={c.data.name}
								class="char-thumb"
								loading="lazy"
								decoding="async"
							/>
						)}
						<div class="card-meta">
							{c.data.rarity && (
								<span class:list={['badge', `rarity-${c.data.rarity.toLowerCase()}`]}>{c.data.rarity}</span>
							)}
							{c.data.danger && <span class="badge">{c.data.danger}</span>}
						</div>
						<h3>{c.data.name}</h3>
						<p>{c.data.description.slice(0, 60)}...</p>
					</a>
				))}
			</div>
		</section>

		<section class="section">
			<div class="section-header">
				<h2 class="section-title">推荐角色</h2>
				<a href="/characters" class="section-more">查看全部 →</a>
			</div>
			<div class="card-grid">
				{recommendedCharacters.map((c) => (
					<a href={`/characters/${c.id}/`} class="card char-card">
						{c.data.image && (
							<img
								src={c.data.image}
								alt={c.data.name}
								class="char-thumb"
								loading="lazy"
								decoding="async"
							/>
						)}
						<div class="card-meta">
							{c.data.rarity && (
								<span class:list={['badge', `rarity-${c.data.rarity.toLowerCase()}`]}>{c.data.rarity}</span>
							)}
							{c.data.danger && <span class="badge">{c.data.danger}</span>}
						</div>
						<h3>{c.data.name}</h3>
						<p>{c.data.description.slice(0, 60)}...</p>
					</a>
				))}
			</div>
		</section>

		<section class="section">
			<div class="section-header">
				<h2 class="section-title">关卡攻略</h2>
				<a href="/stages" class="section-more">查看全部 →</a>
			</div>
			<div class="card-grid">
				{stages.slice(0, 6).map((s) => (
					<a href={`/stages/${s.id}/`} class="card">
						<h3>{s.data.name}</h3>
						<p>{s.data.description.slice(0, 60)}...</p>
					</a>
				))}
			</div>
		</section>

		<section class="section">
			<div class="section-header">
				<h2 class="section-title">玩法攻略</h2>
				<a href="/game-modes" class="section-more">查看全部 →</a>
			</div>
			<div class="card-grid">
				{gameModes.map((m) => (
					<a href={`/game-modes/${m.id}/`} class="card">
						<div class="card-meta">
							{m.data.type && <span class="badge">{m.data.type}</span>}
						</div>
						<h3>{m.data.name}</h3>
						<p>{m.data.description.slice(0, 60)}...</p>
					</a>
				))}
			</div>
		</section>
	</main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

<style>
	.hero {
		text-align: center;
		padding: 3em 1em;
		margin-bottom: 2em;
		background: linear-gradient(180deg, #f8fafc 0%, #fff 100%);
		border-radius: 16px;
		border: 1px solid rgb(var(--gray-light));
	}
	.hero-title {
		font-size: 2.6em;
		margin-bottom: 0.3em;
	}
	.hero-desc {
		font-size: 1.1em;
		color: rgb(var(--gray));
		margin-bottom: 0.5em;
	}
	.hero-sub {
		font-size: 0.95em;
		color: rgb(var(--gray));
		margin-bottom: 1.5em;
	}
	.hero-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		flex-wrap: wrap;
	}
	.hero-btn {
		display: inline-block;
		padding: 0.6em 1.4em;
		border-radius: 8px;
		background: var(--accent);
		color: #fff;
		text-decoration: none;
		font-weight: 500;
		transition: background 0.2s;
	}
	.hero-btn:hover {
		background: var(--accent-dark);
	}
	.hero-btn-secondary {
		background: #fff;
		color: var(--accent-dark);
		border: 1px solid var(--accent);
	}
	.hero-btn-secondary:hover {
		background: #eef2ff;
	}
	.section {
		margin-bottom: 2.5em;
	}
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 0.8em;
	}
	.section-title {
		font-size: 1.5em;
		margin: 0;
	}
	.section-more {
		font-size: 0.85em;
		color: var(--accent);
		text-decoration: none;
	}
	.section-more:hover {
		text-decoration: underline;
	}
	.quick-links {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}
	.quick-link-card {
		text-align: center;
	}
	.quick-link-card h3 {
		color: var(--accent-dark);
	}
	.card-meta {
		margin-bottom: 0.5em;
	}
	.update-list {
		display: grid;
		gap: 0.8em;
	}
	.update-card {
		display: flex;
		align-items: center;
		gap: 1em;
		flex-wrap: wrap;
		padding: 0.9em 1.1em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 10px;
		background: #fff;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s;
	}
	.update-card:hover {
		border-color: var(--accent);
	}
	.update-date {
		font-size: 0.85em;
		color: rgb(var(--gray));
		min-width: 90px;
	}
	.update-type {
		font-size: 0.75em;
		padding: 0.15em 0.5em;
		border-radius: 4px;
		background: #eef2ff;
		color: var(--accent-dark);
	}
	.char-card {
		overflow: hidden;
	}
	.char-thumb {
		width: 100%;
		height: 180px;
		object-fit: cover;
		object-position: top center;
		border-radius: 8px;
		margin-bottom: 0.6em;
		background: rgb(var(--gray-light));
	}
	@media (max-width: 720px) {
		.hero-title { font-size: 2em; }
		.hero { padding: 2em 1em; }
		.char-thumb { height: 220px; }
	}
</style>
