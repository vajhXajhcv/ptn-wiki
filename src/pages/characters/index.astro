---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import Card from '../../components/Card.astro';
import CardGrid from '../../components/CardGrid.astro';
import FilterBar from '../../components/FilterBar.astro';
import { SITE_TITLE } from '../../consts';
import { DANGER_TYPES, RARITIES } from '../../lib/constants';
import '../../styles/global.css';

const characters = (await getCollection('characters')).sort((a, b) => {
	const rarityOrder = { S: 0, A: 1, B: 2 };
	const rarityDiff = rarityOrder[a.data.rarity || 'B'] - rarityOrder[b.data.rarity || 'B'];
	if (rarityDiff !== 0) return rarityDiff;
	return a.data.name.localeCompare(b.data.name, 'zh-CN');
});

const dangers = DANGER_TYPES;
const rarities = RARITIES;
const roles = [
	...new Set(
		characters
			.map((c) => c.data.role)
			.filter(Boolean)
			.map((r) => r!.trim())
	),
].sort((a, b) => a.localeCompare(b, 'zh-CN'));
---

<BaseLayout title={`角色图鉴 - ${SITE_TITLE}`} description="无期迷途全角色图鉴、定位与基础资料。">
	<main>
		<h1 class="page-title">角色图鉴</h1>
		<p class="page-desc">共 {characters.length} 名角色</p>

		<div class="filters">
			<div class="filter-row">
				<input type="text" id="char-search" placeholder="输入角色名、定位或标签..." />
				<select id="role-filter">
					<option value="">全部定位</option>
					{roles.map((r) => <option value={r}>{r}</option>)}
				</select>
			</div>
			<div class="filter-row filter-buttons-row">
				<span class="filter-label">稀有度</span>
				<div class="filter-buttons" data-filter="rarity">
					<button class="active" data-value="all">全部</button>
					{rarities.map((r) => <button data-value={r}>{r}级</button>)}
				</div>
			</div>
			<div class="filter-row filter-buttons-row">
				<span class="filter-label">职业</span>
				<div class="filter-buttons" data-filter="danger">
					<button class="active" data-value="all">全部</button>
					{dangers.map((d) => <button data-value={d}>{d}</button>)}
				</div>
			</div>
		</div>

		<p id="result-count" class="page-desc" style="margin-top: 0;"></p>

		<CardGrid id="char-grid">
			{characters.map((c) => (
				<Card
					href={`/characters/${c.id}/`}
					title={c.data.name}
					subtitle={c.data.title}
					description={`${c.data.description.slice(0, 60)}...`}
					image={c.data.image}
					imageAlt={c.data.name}
					badges={[
						c.data.rarity && { label: `${c.data.rarity}级`, variant: `rarity-${c.data.rarity.toLowerCase()}` as const },
						c.data.danger && { label: c.data.danger },
						c.data.role && { label: c.data.role },
					].filter(Boolean) as { label: string; variant?: string }[]}
					footer={c.data.tags && c.data.tags.length > 0 ? c.data.tags.slice(0, 4).join(' · ') : undefined}
					data-rarity={c.data.rarity || 'B'}
					data-danger={c.data.danger || ''}
					data-role={c.data.role || ''}
					data-search={`${c.data.name} ${c.data.title || ''} ${c.data.role || ''} ${(c.data.tags || []).join(' ')} ${(c.data.aliases || []).join(' ')}`}
				/>
			))}
		</CardGrid>
	</main>
</BaseLayout>

<script>
	const searchInput = document.getElementById('char-search') as HTMLInputElement;
	const roleFilter = document.getElementById('role-filter') as HTMLSelectElement;
	const resultCount = document.getElementById('result-count') as HTMLParagraphElement;
	const cards = Array.from(document.querySelectorAll<HTMLElement>('#char-grid .card'));

	let activeRarity = 'all';
	let activeDanger = 'all';

	function update() {
		const query = searchInput.value.trim().toLowerCase();
		const activeRole = roleFilter.value;
		let visible = 0;

		cards.forEach((card) => {
			const rarity = card.dataset.rarity || '';
			const danger = card.dataset.danger || '';
			const role = card.dataset.role || '';
			const searchText = (card.dataset.search || '').toLowerCase();

			const matchesRarity = activeRarity === 'all' || rarity === activeRarity;
			const matchesDanger = activeDanger === 'all' || danger === activeDanger;
			const matchesRole = !activeRole || role === activeRole;
			const matchesSearch = !query || searchText.includes(query);

			const show = matchesRarity && matchesDanger && matchesRole && matchesSearch;
			card.style.display = show ? '' : 'none';
			if (show) visible++;
		});

		resultCount.textContent = `显示 ${visible} 名角色`;
	}

	document.querySelectorAll<HTMLButtonElement>('[data-filter="rarity"] button').forEach((btn) => {
		btn.addEventListener('click', () => {
			document.querySelectorAll('[data-filter="rarity"] button').forEach((b) => b.classList.remove('active'));
			btn.classList.add('active');
			activeRarity = btn.dataset.value || 'all';
			update();
		});
	});

	document.querySelectorAll<HTMLButtonElement>('[data-filter="danger"] button').forEach((btn) => {
		btn.addEventListener('click', () => {
			document.querySelectorAll('[data-filter="danger"] button').forEach((b) => b.classList.remove('active'));
			btn.classList.add('active');
			activeDanger = btn.dataset.value || 'all';
			update();
		});
	});

	roleFilter.addEventListener('change', update);
	searchInput.addEventListener('input', update);
	update();
</script>

<style>
	.filters {
		margin-bottom: 1.5em;
		padding: 1em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		background: var(--bg-card);
	}
	.filter-row {
		display: flex;
		gap: 0.75em;
		align-items: center;
		margin-bottom: 0.8em;
		flex-wrap: wrap;
	}
	.filter-row:last-child {
		margin-bottom: 0;
	}
	.filter-row input {
		flex: 1 1 220px;
		padding: 0.5em 0.75em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		font-size: 1em;
		font-family: inherit;
	}
	.filter-row select {
		padding: 0.5em 0.75em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		font-size: 1em;
		font-family: inherit;
		background: #fff;
		min-width: 140px;
	}
	.filter-label {
		font-weight: 600;
		color: rgb(var(--black));
		font-size: 0.9em;
		min-width: 3em;
	}
	.filter-buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
	}
	.filter-buttons button {
		padding: 0.35em 0.75em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		background: #fff;
		font-size: 0.9em;
		cursor: pointer;
		font-family: inherit;
	}
	.filter-buttons button.active {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
	}
	:global(.card-image) {
		aspect-ratio: 1;
		object-fit: cover;
	}
</style>
