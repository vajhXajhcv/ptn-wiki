---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DetailHeader from '../../components/DetailHeader.astro';
import JsonLd from '../../components/JsonLd.astro';
import { SITE_TITLE } from '../../consts';
import { breadcrumbJsonLd, articleJsonLd } from '../../lib/seo';
import '../../styles/global.css';

export async function getStaticPaths() {
	const characters = await getCollection('characters');
	return characters.map((character) => ({
		params: { id: character.id },
		props: { character },
	}));
}

const { character } = Astro.props;
const { Content } = await render(character);
const title = `${character.data.name} - ${SITE_TITLE}`;
const ogImage = character.data.image || undefined;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const d = character.data;

const breadcrumbItems = [
	{ label: '首页', href: '/' },
	{ label: '角色图鉴', href: '/characters' },
	{ label: d.name },
];

const badges = [
	d.rarity && { label: `${d.rarity}级`, variant: `rarity-${d.rarity.toLowerCase()}` as const },
	d.danger && { label: d.danger },
	d.role && { label: d.role },
	d.faction && { label: d.faction },
].filter(Boolean) as { label: string; variant?: string }[];

const tags = (d.tags || []).map((tag) => ({ label: tag, variant: 'tag' as const }));
---

<BaseLayout title={title} description={d.description} image={ogImage}>
	<main>
		<Breadcrumbs items={breadcrumbItems} />

		<DetailHeader
			title={d.name}
			description={d.title}
			image={d.image}
			imageAlt={d.name}
			badges={[...badges, ...tags]}
		/>

		{d.aliases && d.aliases.length > 0 && (
			<p class="character-aliases">
				<strong>别名：</strong>{d.aliases.join('、')}
			</p>
		)}

		{d.description && <p class="character-description">{d.description}</p>}

		<div class="prose character-body">
			<Content />
		</div>

		<p class="data-source">
			角色图片素材来自《无期迷途》官方网站；技能名称、效果等客观数据参考无期迷途 BWiki 整理。
			{d.imageSource && (
				<>
					<br />
					当前图片源自
					<a href={d.imageSource.url} target="_blank" rel="noopener noreferrer">
						「{d.imageSource.title}」
					</a>
					（{d.imageSource.category}）
				</>
			)}
		</p>
	</main>

	<JsonLd data={breadcrumbJsonLd(breadcrumbItems, Astro.site)} />
	<JsonLd data={articleJsonLd({ title, description: d.description, url: canonicalUrl, site: Astro.site, image: ogImage })} />
</BaseLayout>

<style>
	.character-aliases {
		margin: -0.5em 0 1em;
		color: rgb(var(--gray));
		font-size: 0.95em;
	}
	.character-description {
		margin: 0 0 1.5em;
		color: rgb(var(--gray-dark));
		font-size: 1.05em;
		line-height: 1.7;
	}
	.character-body {
		margin-top: 1.5em;
	}
</style>
