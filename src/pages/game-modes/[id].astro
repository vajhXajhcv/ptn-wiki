---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DetailHeader from '../../components/DetailHeader.astro';
import JsonLd from '../../components/JsonLd.astro';
import { SITE_TITLE } from '../../consts';
import { breadcrumbJsonLd, articleJsonLd } from '../../lib/seo';
import '../../styles/global.css';

export async function getStaticPaths() {
	const modes = await getCollection('gameModes');
	return modes.map((mode) => ({
		params: { id: mode.id },
		props: { mode },
	}));
}

const { mode } = Astro.props;
const { Content } = await render(mode);
const title = `${mode.data.name} - ${SITE_TITLE}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const breadcrumbItems = [
	{ label: '首页', href: '/' },
	{ label: '玩法攻略', href: '/game-modes' },
	{ label: mode.data.name },
];

const badges = [
	mode.data.type && { label: mode.data.type },
	...(mode.data.tags || []).map((tag) => ({ label: tag, variant: 'tag' as const })),
].filter(Boolean) as { label: string; variant?: 'default' | 'tag' }[];

const meta = [
	mode.data.unlock && { label: '解锁条件', value: mode.data.unlock },
	mode.data.rewards && { label: '主要奖励', value: mode.data.rewards },
].filter(Boolean) as { label: string; value: string }[];
---

<BaseLayout title={title} description={mode.data.description} image={mode.data.image}>
	<main>
		<Breadcrumbs items={breadcrumbItems} />

		<DetailHeader
			title={mode.data.name}
			description={mode.data.description}
			image={mode.data.image}
			badges={badges}
			meta={meta}
		/>

		<div class="prose mode-body">
			<Content />
		</div>
	</main>

	<JsonLd data={breadcrumbJsonLd(breadcrumbItems, Astro.site)} />
	<JsonLd data={articleJsonLd({ title, description: mode.data.description, url: canonicalUrl, site: Astro.site, image: mode.data.image })} />
</BaseLayout>

<style>
	.mode-body {
		margin-top: 1.5em;
	}
	.mode-body h2 {
		margin-top: 1.5em;
	}
	.mode-body h3 {
		margin-top: 1.2em;
		color: var(--accent-dark);
	}
</style>
