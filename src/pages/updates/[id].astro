---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DetailHeader from '../../components/DetailHeader.astro';
import JsonLd from '../../components/JsonLd.astro';
import { SITE_TITLE } from '../../consts';
import { breadcrumbJsonLd, articleJsonLd } from '../../lib/seo';
import '../../styles/global.css';

export async function getStaticPaths() {
	const updates = await getCollection('updates');
	return updates.map((update) => ({
		params: { id: update.id },
		props: { update },
	}));
}

const { update } = Astro.props;
const { Content } = await render(update);
const title = `${update.data.title} - ${SITE_TITLE}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const d = update.data;

const breadcrumbItems = [
	{ label: '首页', href: '/' },
	{ label: '更新日志', href: '/updates' },
	{ label: d.title },
];

const badges = [
	{ label: d.type },
	{ label: d.date },
	d.endDate && { label: `至 ${d.endDate}` },
].filter(Boolean) as { label: string }[];
---

<BaseLayout title={title} description={d.description} image={d.cover}>
	<main>
		<Breadcrumbs items={breadcrumbItems} />

		<DetailHeader
			title={d.title}
			description={d.description}
			image={d.cover}
			badges={badges}
		/>

		<div class="prose update-body">
			<Content />
		</div>

		{d.source && (
			<p class="data-source">
				本文来自《无期迷途》官方网站：
				<a href={d.source} target="_blank" rel="noopener noreferrer">
					{d.source}
				</a>
			</p>
		)}
	</main>

	<JsonLd data={breadcrumbJsonLd(breadcrumbItems, Astro.site)} />
	<JsonLd data={articleJsonLd({ title, description: d.description, url: canonicalUrl, site: Astro.site, image: d.cover, datePublished: d.date })} />
</BaseLayout>

<style>
	.update-body {
		margin-top: 1.5em;
	}
	.update-body h2 {
		margin-top: 1.5em;
	}
	.update-body h3 {
		margin-top: 1.2em;
		color: var(--accent-dark);
	}
</style>
